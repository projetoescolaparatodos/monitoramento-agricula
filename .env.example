# OpenRouter (obrigatório para o chatbot com IA)
# ATENÇÃO: variáveis VITE_* são embutidas no bundle do frontend no momento
# do BUILD — no Render, defina-as no painel de Environment antes do deploy.
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Drive API (opcional — melhora a reprodução de vídeos)
VITE_GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here

# Servidor (local). No Render o PORT é injetado automaticamente
# e o NODE_ENV=production já é definido pelo script "npm start".
PORT=5000
